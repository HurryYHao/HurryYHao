# 项目环境配置
# 复制此文件为 .env 并根据需要修改配置

# 数据存储路径 (可选，默认为项目根目录的 data 文件夹)
DATA_STORAGE_PATH=

# 鑫云平台账号
XINYUN_PHONE=your_phone_number
XINYUN_PASSWORD=your_password
XINYUN_TENANT_ID=your_tenant_id
XINYUN_AUTH_TOKEN=your_auth_token

# 调度参数
POLL_INTERVAL_SECONDS=30
SNAPSHOT_INTERVAL_MINUTES=30
LOGIN_RETRY_MAX=3
TOKEN_REFRESH_THRESHOLD_SECONDS=300

# 端口与环境
DEPLOY_RUN_PORT=5000
COZE_PROJECT_ENV=PROD
COZE_PROJECT_DOMAIN_DEFAULT=

# AI API 配置
ZHENJING_API_KEY=your_api_key
ZHENJING_BASE_URL=https://zhenjing.top/v1
ZHENJING_MODEL=gpt-4o-mini

# Node.js 环境
NODE_ENV=production
